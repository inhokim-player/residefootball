CRON_SECRET=change_me

# API-Football source
API_FOOTBALL_KEY=your_api_football_key
API_FOOTBALL_PLAYERS_URL=https://v3.football.api-sports.io/players
API_FOOTBALL_MAX_PAGES=30

# Age filter (UNDER U25)
API_FOOTBALL_MAX_AGE=24

# Optional league/sort overrides (leave empty for global pool)
# API_FOOTBALL_LEAGUE_IDS=39,140,78,135,61
API_FOOTBALL_SORT=value:desc
API_FOOTBALL_SEASON=2025

# GitHub write-back
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
REGISTERED_PLAYERS_FILE_PATH=data/registered_players.json
DAILY_PLAYER_UPDATES_FILE_PATH=data/daily_player_updates.json

# Optional external sync trigger (if you use separate API service)
# API_SYNC_TRIGGER_URL=https://api.residefootball.com/system/sync
# API_SYNC_TRIGGER_SECRET=change_me
